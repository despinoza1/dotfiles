[user]
	email = contact@daniel-espinoza.com
	user = Daniel Espinoza
	name = Daniel Espinoza
	signingkey = /home/daniel/.ssh/id_ed25519.pub

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[init]
	defaultBranch = main

[core]
	pager = less -F -X
	fsmonitor = true
	untrackedcache = true

[fetch]
	writeCommitGraph = true

[pull]
	ff = only
	rebase = true

[branch]
	sort = -committerdate

[column]
	ui = auto

[rerere]
	enabled = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[commit]
	gpgsign = true

[gpg]
	format = ssh

[maintenance]
	auto = false
	strategy = incremental
